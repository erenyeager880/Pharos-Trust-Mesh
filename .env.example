RPC_URL=https://atlantic.dplabs-internal.com

# Required for Atlantic writes (registerExecution, completeLayer, finalizeExecution).
PRIVATE_KEY=0xYOUR_EXECUTOR_PRIVATE_KEY

# Optional but recommended for real multi-agent testnet runs.
# If both are set, verifier approvals use these independent wallets.
# If omitted, the demo runner uses deterministic verifier wallets and funds them from PRIVATE_KEY.
VERIFIER_B_PRIVATE_KEY=0xYOUR_VERIFIER_B_PRIVATE_KEY
VERIFIER_C_PRIVATE_KEY=0xYOUR_VERIFIER_C_PRIVATE_KEY

# See references/testing.md for forge test + verify-execution checklist.
